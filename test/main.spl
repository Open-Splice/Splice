print("Testing calculator")
func calculator(num1, num2, op) {
    if (op == "+") {
        print(num1 + num2);
    } else if (op == "-") {
        print(num1 - num2);
    }
}

calculator(5, 3, "+");   
calculator(5, 6, "-");   
print("Testing For loops")
print("For loops in Splice");
for i in 1 .. 10 {
  print(i);
}
